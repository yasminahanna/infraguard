# ──────────────────────────────────────────────────────────────────────────
# PRODUCTION env template for the Azure VM deployment.
# Copy to `.env` ON THE VM and fill in real values. NEVER commit the real .env.
#   cp .env.prod.example .env   (then edit)
# Used by: docker compose -f docker-compose.prod.yml --env-file .env up -d --build
# ──────────────────────────────────────────────────────────────────────────

# --- EEP gateway auth (machine-to-machine API key for /v1/analyze) ---
# Use a long random value in prod (e.g. `openssl rand -hex 24`). This is the
# DEPLOYED_API_KEY you pass to the hosted e2e test.
API_KEY=CHANGE_ME_long_random_value

# --- Public URLs (fill AFTER the VM has a public IP) ---
# The frontend is built to call the EEP at this URL (browser -> public EEP):
PUBLIC_EEP_URL=http://CHANGE_ME_VM_PUBLIC_IP:8000
# CORS allow-list on the EEP = the public origin(s) the dashboard is served from.
# Frontend runs on port 80, so the origin has no port suffix:
FRONTEND_ORIGINS=http://CHANGE_ME_VM_PUBLIC_IP

# --- LLM (OpenAI) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME_openai_key
LLM_MODEL=gpt-4o-mini
# Slightly higher than local 12s so a single slow call doesn't flip a report to fallback:
LLM_TIMEOUT_SECONDS=30

# --- RAG (Tavily) — leave disabled until a key is available ---
WEB_SEARCH_ENABLED=false
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# --- Request limits / timeouts ---
MAX_FRAMES_PER_REQUEST=8
MAX_PAYLOAD_MB=10
REQUEST_TIMEOUT_SECONDS=360

# --- Supabase admin auth (dashboard gating) ---
# REQUIRE_SUPABASE_AUTH defaults to true in the prod compose; keep it true.
REQUIRE_SUPABASE_AUTH=true
SUPABASE_URL=https://CHANGE_ME.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME_supabase_anon_key
# Comma-separated emails allowed to log into the admin dashboard:
SUPABASE_ADMIN_EMAILS=nasrallahmohamad@hotmail.com

# --- Grafana (kept internal; still set a real password) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
